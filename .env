# Токен бота от BotFather (замените на ваш токен)
BOT_TOKEN=your_bot_token_here

# API ключ Google Gemini для анализа тренировок (замените на ваш ключ)
GEMINI_API_KEY=your_gemini_api_key_here

# URL подключения к базе данных PostgreSQL
# Формат: postgresql://user:password@host:port/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sports_dairy_db
